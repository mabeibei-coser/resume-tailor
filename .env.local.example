# Resume Tailor · 环境变量示例
# 复制本文件为 .env.local 并填入真实值（.env.local 已被 .gitignore 忽略）

# ============================================================
# 讯飞星辰 LLM（主模型 · 所有 AI 调用统一走这里）
# ============================================================
IFLYTEK_API_KEY=
# 可选：自定义 baseURL / 模型名
# 默认 https://maas-coding-api.cn-huabei-1.xf-yun.com/v2 / astron-code-latest
IFLYTEK_BASE_URL=
IFLYTEK_MODEL=

# ============================================================
# 火山引擎 TTS / ASR（V3 BigTTS / 批量 ASR Flash）
# 注意：TTS 与 ASR 共享同一对 APP_KEY / ACCESS_KEY
# ============================================================
VOLC_TTS_APP_KEY=
VOLC_TTS_ACCESS_KEY=
# 可选：指定 TTS 发音人（默认 zh_female_vv_uranus_bigtts）
VOLC_TTS_SPEAKER=
# 可选：ASR 资源 ID（默认 volc.bigasr.auc_turbo）
VOLC_ASR_RESOURCE_ID=
