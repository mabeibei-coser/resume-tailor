# Resume Tailor · 环境变量示例
# 复制本文件为 .env.local 并填入真实值（.env.local 已被 .gitignore 忽略）

# ============================================================
# MiniMax LLM（主模型 · /api/interview/question 用 Q2 追问）
# ============================================================
MINIMAX_API_KEY=
# 可选：自定义 baseURL / 模型名（默认 https://api.minimaxi.com/v1 / MiniMax-Text-01）
MINIMAX_BASE_URL=
MINIMAX_MODEL=

# ============================================================
# 讯飞星辰 LLM（fallback · 未配置则单路 MiniMax，调用方无感）
# ============================================================
IFLYTEK_API_KEY=
IFLYTEK_BASE_URL=
IFLYTEK_MODEL=

# ============================================================
# 火山引擎 TTS / ASR（V3 BigTTS / 批量 ASR Flash）
# 注意：TTS 与 ASR 共享同一对 APP_KEY / ACCESS_KEY
# ============================================================
VOLC_TTS_APP_KEY=
VOLC_TTS_ACCESS_KEY=
# 可选：指定 TTS 发音人（默认 zh_female_vv_uranus_bigtts）
VOLC_TTS_SPEAKER=
# 可选：ASR 资源 ID（默认 volc.bigasr.auc_turbo）
VOLC_ASR_RESOURCE_ID=
